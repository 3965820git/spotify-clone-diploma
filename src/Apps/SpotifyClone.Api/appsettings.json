{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "MainDb": "Host={DB_HOST};Port={DB_PORT};Database={DB};Username={DB_USERNAME};Password={DB_PASSWORD}",
        "Redis": "{REDIS_HOST}:{REDIS_PORT}"
    },
    "Jwt": {
        "Issuer": "{JWT_ISSUER}",
        "Audience": "{JWT_AUDIENCE}",
        "AccessTokenLifetimeMinutes": 15,
        "RefreshTokenLifetimeDays": 30,
        "SecretKey": "{JWT_SECRET_KEY}"
    },
    "Authentication": {
        "Google": {
            "ClientId": "{GOOGLE_CLIENT_ID}",
            "ClientSecret": "{GOOGLE_CLIENT_SECRET}"
        }
    },
    "Smtp": {
        "Host": "{SMTP_HOST}",
        "Port": "{SMTP_PORT}",
        "EnableSsl": true,
        "UserName": "{SMTP_USERNAME}",
        "Password": "{SMTP_PASSWORD}",
        "DefaultFromEmail": "noreply@spotifyclone.com",
        "DefaultFromName": "SpotifyClone Team"
    },
    "Application": {
        "DomainName": "SpotifyClone",
        "FrontendUrl": "{FRONTEND_URL}",
        "ApiUrl": "{API_URL}"
    },
    "FFmpegConfig": {
        "ExecutablesPath": ""
    },
    "Minio": {
        "Endpoint": "{MINIO_HOST}",
        "Port": "{MINIO_PORT}",
        "StorageUrl": "{MINIO_STORAGE_URL}",
        "LocalScratchPath": "/app/wwwroot/temp/conversion",
        "AudioBucketName": "audio",
        "ImageBucketName": "images",
        "AccessKey": "{MINIO_ACCESS_KEY}",
        "SecretKey": "{MINIO_SECRET_KEY}"
    }
}
